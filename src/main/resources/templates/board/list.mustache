{{> layout/header}}

<div class="container my-3">
    <div class="card">
        <div class="card-header">
            <h3>📝 게시글 목록</h3>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>번호</th>
                        <th>제목</th>
                        <th>내용 요약</th>
                        <th>작성자</th>
                    </tr>
                </thead>
                <tbody>
                    {{#models}}
                    <tr>
                        <td>{{id}}</td>
                        <td>{{title}}</td>
                        <td>{{content}}</td>
                        <td>{{username}}</td>
                    </tr>
                    {{/models}}
                </tbody>
            </table>
        </div>
    </div>
</div>

{{> layout/footer}}
