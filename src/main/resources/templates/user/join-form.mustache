{{> layout/header}}

<div class="container my-3">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold">회원가입</h5>
        </div>
        <div class="card-body p-4">
            <form action="/join" method="post" onsubmit="return validateForm()">
                <div class="mb-3">
                    <label for="username" class="form-label small text-muted">아이디</label>
                    <div class="input-group">
                        <input type="text" id="username" name="username" class="form-control" placeholder="아이디를 입력하세요" required>
                        <button type="button" class="btn btn-outline-primary" onclick="checkUsername()">중복체크</button>
                    </div>
                    <div id="username-msg" class="mt-1 small"></div>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label small text-muted">비밀번호</label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="비밀번호를 입력하세요" required>
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label small text-muted">이메일</label>
                    <input type="email" id="email" name="email" class="form-control" placeholder="이메일을 입력하세요" required>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 mt-3 fw-bold">회원가입</button>
            </form>
        </div>
    </div>
</div>

<script>
    let isUsernameChecked = false;

    async function checkUsername() {
        let username = document.querySelector("#username").value;

        if (username.trim() === "") {
            alert("아이디를 입력해주세요.");
            return;
        }

        let response = await fetch(`/api/user/username-same-check?username=${username}`);
        let responseBody = await response.json();

        let msgElement = document.querySelector("#username-msg");
        if (responseBody.body === true) {
            msgElement.innerText = "중복된 아이디입니다.";
            msgElement.classList.remove("text-success");
            msgElement.classList.add("text-danger");
            isUsernameChecked = false;
        } else {
            msgElement.innerText = "사용 가능한 아이디입니다.";
            msgElement.classList.remove("text-danger");
            msgElement.classList.add("text-success");
            isUsernameChecked = true;
        }
    }

    function validateForm() {
        if (!isUsernameChecked) {
            alert("아이디 중복체크를 먼저 진행해주세요.");
            return false;
        }
        return true;
    }
</script>

{{> layout/footer}}
